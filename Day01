//problem 4- Swap values of two variables using third
#include<iostream>
using namespace std;

int main(){
    int a;
    int b;
    
    cin>> a >> b;
    
    //Swap
    
    int temp = a;
    a = b;
    b = temp;
    
    cout<< a << " \n" << b << endl;
    
    return 0;
}


// Problem 5- Area of shapes
//1-- circle, 2-- rectangle, 3-- triangle
#include<iostream>
using namespace std;

int main(){
    int choice;
    cin >> choice;
    
    if(choice == 1){
        double radius;
        cin >> radius;
        cout << 3.14*radius*radius << endl;
    } else if(choice == 2){
        double length, breadth;
        cin >> length >> breadth;
        cout<< length*breadth<< endl;
    } else if(choice ==3){
        double base, height;
        cin >> base >> height;
        cout<< 0.5*base*height << endl;
    } else{
        cout << "Invalid choice " << endl;
        
    }
    
    return 0;
}


