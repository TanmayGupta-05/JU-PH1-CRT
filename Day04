//Problem 8 -- print a hollow square using star pattern
// * * * * * *
// *         *
// *         *
// *         *
// *         *
// * * * * * *
#include <iostream>
using namespace std;
int main()
{
    int n = 5;
    for(int i = 1; i<=n; i++){
        for(int j = 1; j<=n; j++){
            cout << " ";
            if((i==1) || (j==1) || (i==n) || (j==n)){
                cout << "*";
            }else{
                cout << " ";
            }
            
        }
        cout << " \n";
    }
    return 0;
}
