//Problem 6 -- print inverted right angled triangle using star pattern
// *****
// ****
// ***
// **
// *
#include <iostream>
using namespace std;
int main()
{
    for(int i = 5; i >= 1; i--){
        for(int j = 1; j<= i; j++){
            cout<<"* ";
        }
        cout << "\n";
    }
    return 0;
}


