#include<iostream>
using namespace std;

bool isPallindrome(string str){
    int start = 0;
    int end = str.size()-1;
    
    while(start < end){
        if(str[start] != str[end]){
            return false;
            
        }
        start++;
        end--;
    }
    return true;
    
};


int main(){
    string str;
    cout << "enter a string: ";
    cin >> str;
    
    if(isPallindrome(str)){
        cout << "pallindrome string\n";
    }else{
        cout << "not pallindrome";
    }
}
