// INSERT DATA AT HEAD OF LL

#include <iostream>
using namespace std;

class Node{
    public:
    int data;
    Node* next;
    
    Node(int newData){
        this->data = newData;
        this->next = nullptr;
    }
};

Node* head = nullptr;

// Function to insert at head
void insertAtHead(int value){
    Node* newNode = new Node(value);
    newNode->next = head;
    head = newNode;
}

void traversal(){
    Node* temp = head;   // use temp so head does not change

    while(temp != nullptr){
        cout << temp->data << " -> ";
        temp = temp->next;
    }
    cout << "NULL";
}

int main()
{
    head = new Node(10);
    head->next = new Node(20);
    head->next->next = new Node(30);
    head->next->next->next = new Node(40);

    // Insert 5 at head
    insertAtHead(5);

    traversal();

    return 0;
}
