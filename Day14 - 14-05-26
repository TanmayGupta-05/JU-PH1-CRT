LINKED LIST
//Create and traversal in a linked list
#include <iostream>
using namespace std;

class Node{
    public:
    int data;
    Node* next;
    
    Node(int newData){
        this ->data = newData;
        this -> next = nullptr;
    }
};

Node* head = nullptr;
void traversal(){
    while(head != nullptr){
        cout << head -> data << "-> ";
        head = head -> next;
    }
}

int main()
{
    
    head = new Node(10);
    head -> next = new Node(20);
    head -> next -> next = new Node(30);
    head -> next -> next -> next = new Node(40);
    traversal();

    return 0;
}

