//problem 1 -- print values from 1-10 using for loop
#include <iostream>
using namespace std;

int main(){
    for(int i= 1; i<=10; i++){
        cout << i << " \n";
    }
    return 0;
}

//problem 2 -- print values from 10-1 using for loop
#include <iostream>
using namespace std;

int main(){
    for(int i= 10; i>=1; i--){
        cout << i << " \n";
    }
    return 0;
}
