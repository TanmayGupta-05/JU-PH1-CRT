//problem 1 -- print values from 1-10 using for loop
#include <iostream>
using namespace std;

int main(){
    for(int i= 1; i<=10; i++){
        cout << i << " \n";
    }
    return 0;
}

//problem 2 -- print values from 10-1 using for loop
#include <iostream>
using namespace std;

int main(){
    for(int i= 10; i>=1; i--){
        cout << i << " \n";
    }
    return 0;
}


//problem 3 -- print values from 1-10 using while loop
#include <iostream>
using namespace std;

int main(){
    int i = 1;
    while(i<=10){
        cout<< i << " ";
        i++;
    }
    return 0;
}

//problem 4 -- print values from 10-1 using while loop
#include <iostream>
using namespace std;

int main(){
    int i = 10;
    while(i>=1){
        cout<< i << " ";
        i--;
    }
    return 0;
}

//problem 5 -- print values from 1-10 using do while loop
#include <iostream>
using namespace std;

int main(){
    int i = 1;
    do{
        cout<< i << " ";
        i++;
    }while(i<=10);
    return 0;
}

//problem 6 -- print values from 10-1 using do while loop
#include <iostream>
using namespace std;

int main(){
    int i = 10;
    do{
        cout<< i << " ";
        i--;
    }while(i>=1);
    return 0;
}

//problem 7 -- print the factorial of a number
#include <iostream>
using namespace std;

int main(){
    int n;
    cout<< "Enter the number: ";
    cin>> n;
    
    long fact = 1;
    
    for(int i = 1; i<=n ; i++){
        fact*=i;
    }
    cout << fact;
    return 0;
}

//problem 8 -- print the fabonacci series
#include <iostream>
using namespace std;

int main(){
    int n;
    cout << "Enter the number: ";
    cin >> n;
    
    int a =0, b = 1;
    
    for(int i = 0; i < n; i++){
        cout << a << " ";
        int c = a+b;
        a=b;
        b=c;
    }
    return 0;
}
