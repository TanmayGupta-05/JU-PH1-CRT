FACTORIAL OF A NUMBER USING RECURSION
#include <iostream>
using namespace std;

int fact(int n){
    //base
    if(n == 0 || n == 1){
        return 1;
    }
    
    //logic
    return n * fact(n-1);
}

int main(){
    int n = 6;
    cout << "The factorial of a given number is: " << fact(n);
    return 0;
}
