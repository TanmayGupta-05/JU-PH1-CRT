//Problem -- 2 
//Constructor overriding

#include<iostream>
using namespace std;

class Rectangle{
    public:
    int length;
    int width;
    
    Rectangle(){
        length = 1;
        width = 1;
    }
    Rectangle(int side){
        length = side;
        width = side;
    }
    
    Rectangle(int side1, int side2){
        length = side1;
        width = side2;
    }
    
    void showArea(){
        
        cout << length*width << "\n";
    }
};


int main(){
    Rectangle rect1;
    Rectangle rect2(5);
    Rectangle rect3(5, 4);
    rect1.showArea();
    rect2.showArea();
    rect3.showArea();
}
