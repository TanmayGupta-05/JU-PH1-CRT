//Problem 2 -- Access Specifier
//7.3 protected

#include <iostream>
using namespace std;

class Parent{
    protected:
    int secretCode = 6969;  
};

class Child : public Parent{
    public:
    void accessOfSecretCode(){
        cout << "Secret code of the locker is: " << secretCode;
    }
};

int main()
{
    Child obj1;
    obj1.accessOfSecretCode();
}
