//Types of polymorphism -- 2.2 
//function overriding

#include <iostream>
using namespace std;

class Animal{
    public:
    virtual void sound(){
        cout << "Animal makes sound\n";
    }
};

class Dog : public Animal{
    public:
    void sound() override {
        cout << "Dog is barking\n";
    }
};

class Cat : public Animal{
    public:
    void sound() override {
        cout << "Cat says meowwww..\n";
    }
};

int main()
{
    Dog dawg;
    Cat kitler;
    kitler.sound();
    dawg.sound();
}

