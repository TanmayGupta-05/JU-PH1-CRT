#include <iostream>
using namespace std;

class Parent1{
    public:
    void slap(){
        cout << "Mom beating yo ass\n";
    }
};

class Parent2{
    public:
    void slap(){
        cout << "Dad kickin yo ass\n";
    }
};

class child : public Parent1, public Parent2{
    
};

int main()
{
    child obj1;
    obj1.Parent1::slap();
    obj1.Parent2::slap(); //to avoid ambiguity we need to specify which parent to call
    
}

