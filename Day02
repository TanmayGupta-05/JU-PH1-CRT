//problem 2 -- if-else condition
//to verify the eligible voting age

#include <iostream>
using namespace std;
int main()
{
   int age;
  cin >> age;
  if(age>=18){
      cout << "you are eligible to vote"; 
  }else{
      cout<< "you are ineligible";
  }
  return 0;
   
}


//problem 3 -- NESTED if-else condition
//to verify the eligible voting age

#include <iostream>
using namespace std;
int main()
{
   int age;
   cin >> age;
   
   if(age>=18){
       if(age >=100){
           cout << "eligible but we are super senior oldies";
       }else{
           cout<< "eligible for vote";
       }
   } else{
       if(age<0){
           cout<< "enter a valid age number";
       }else{
           cout<< "not eligible for vote";
       }
   }
   return 0;
   
}


//problem 4 -- Ternary operator
//find the greater number among two

#include <iostream>
using namespace std;
int main()
{
   int a, b;
   int max_Num;
   
   cin>> a>> b;
   //Ternary operator
   max_Num = (a>b)? a:b;
   cout<< max_Num;
   return 0;
}


//problem 5 -- Continue statement
//print 1-n and avoid those numbers whoch are not divisible by 3

#include <iostream>
using namespace std;
int main()
{
   int n;
   cin>>n;
   
   for(int i =1; i<=n; i++){
       if(i%3==0){
           continue;
       }
       cout << i << " ";
   }
   cout << "\n";
   return 0;
}
