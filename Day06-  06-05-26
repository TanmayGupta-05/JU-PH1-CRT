//Problem 1 --
//Swapping the values of two variables using pointers with swap functio 
#include <iostream>
using namespace std;\
void swapNumber(int* x, int* y){
    
    //swap
    int temp = *x;
    *x = *y;
    *y = temp;
}

int main()
{
    int a;
    int b;
    cin>>a;
    cin>>b;
    
    swapNumber(&a, &b);
    cout << a << " " << b;
    return 0;
}
