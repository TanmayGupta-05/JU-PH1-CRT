//PRACTICE PROBLEMS
//Problem -5
//Smart AC remote- FUnction overloadinng, Default Args

#include <iostream>
using namespace std;

void setTemp(int temp = 22){
    cout << "temperature set to " << temp << "°C \n";
}
void setTemp(double temp){
    cout << "temperature set to " << temp << "°C \n";
}

void setTemp(string mode){
    if(mode == "ECO"){
        cout << "Temperaature set to 24°C \n";
    }else if(mode == "TURBO"){
        cout << "Temperature set to 18°C";
    }
}
int main(){
    setTemp() ; //default value -- 22
    setTemp(20.5); //manually setting the temp
    setTemp("ECO")  ; //set temp to 24
    setTemp("TURBO")   ; //set temp to 18
}
