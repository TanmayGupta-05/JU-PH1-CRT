//Problem 2- function with argument and return type 

#include <iostream>
using namespace std;

int area(int a, int b){
    return a*b;
}


int main(){
    int length = 10;
    int width = 5;
    int areaOfRect = area(length, width);
    cout << areaOfRect;
    
    return 0;
}
