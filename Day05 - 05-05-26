//Problem 5 -- Pointers

#include <iostream>
using namespace std;

int main(){
    int age = 24;
    int *ptr = &age;
    
    cout << age << "\n";
    cout << ptr << "\n";
    cout << *ptr << "\n";
    
    *ptr = 28; //dereferencing of a var
    
    cout << *ptr ;
}
